# Frontend (Vite) — these are PUBLIC (anon key is safe to expose; RLS protects data).
# Dev: copy to .env.local. Prod: set as Render Static Site env vars.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-side secrets (NOT used by the frontend; set as Supabase secrets) ---
# supabase secrets set SMTP2GO_API_KEY=... SMTP2GO_SENDER="SWNZ Content <noreply@yourdomain>" PUBLIC_APP_URL=https://swnz-content.onrender.com
